# LLM for autonomous ideation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hosted image/video generation (fal.ai)
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_VIDEO_MODEL=fal-ai/minimax/video-01-live

# YouTube upload
YOUTUBE_CLIENT_SECRET_PATH=/app/secrets/client_secret.json
YOUTUBE_TOKEN_PATH=/app/secrets/token.json
YOUTUBE_CATEGORY_ID=24
YOUTUBE_PRIVACY_STATUS=public

# Local processing
MAX_THREADS=12
WORKDIR=/app/data
MUSIC_DIR=/app/music
